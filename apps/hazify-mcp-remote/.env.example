# Transport mode
HAZIFY_MCP_TRANSPORT=http
HAZIFY_MCP_HTTP_HOST=0.0.0.0
PORT=8788
HAZIFY_MCP_HTTP_PORT=8788

# Remote MCP production mode (recommended)
HAZIFY_MCP_INTROSPECTION_URL=https://hazify-license-service-production.up.railway.app
HAZIFY_MCP_API_KEY=change-this-mcp-api-key
HAZIFY_MCP_PUBLIC_URL=https://hazify-mcp-remote-production.up.railway.app/mcp
HAZIFY_MCP_AUTH_SERVER_URL=https://hazify-license-service-production.up.railway.app
HAZIFY_MCP_ALLOWED_ORIGINS=
HAZIFY_MCP_CONTEXT_TTL_MS=0
SHOPIFY_API_VERSION=2026-01

# Section workflow artifact store
HAZIFY_SECTION_ARTIFACT_MODE=hybrid
HAZIFY_SECTION_ARTIFACT_MAX_PER_TENANT=200
HAZIFY_SECTION_ARTIFACT_SWEEP_INTERVAL_MS=600000
HAZIFY_SECTION_ARTIFACT_PURGE_INTERVAL_MS=3600000
HAZIFY_SECTION_ARTIFACT_PERSIST_URL=https://hazify-license-service-production.up.railway.app
HAZIFY_SECTION_ARTIFACT_PERSIST_API_KEY=change-this-mcp-api-key
HAZIFY_SECTION_ARTIFACT_PERSIST_TIMEOUT_MS=8000
HAZIFY_SECTION_ARTIFACT_TTL_INSPECTION_MS=7200000
HAZIFY_SECTION_ARTIFACT_TTL_BUNDLE_MS=86400000
HAZIFY_SECTION_ARTIFACT_TTL_VALIDATION_MS=86400000
HAZIFY_SECTION_ARTIFACT_TTL_IMPORT_MS=2592000000

# Internal adapter bridge subprocesses (v1: stdio only)
HAZIFY_SECTION_CHROME_MCP_STDIO_COMMAND=
HAZIFY_SECTION_CHROME_MCP_STDIO_ARGS=
HAZIFY_SECTION_CHROME_MCP_STDIO_CWD=
HAZIFY_SECTION_SHOPIFY_DEV_MCP_STDIO_COMMAND=
HAZIFY_SECTION_SHOPIFY_DEV_MCP_STDIO_ARGS=
HAZIFY_SECTION_SHOPIFY_DEV_MCP_STDIO_CWD=
# Future transport placeholder (HTTP bridge disabled in v1 runtime)
HAZIFY_SECTION_CHROME_MCP_BASE_URL=
HAZIFY_SECTION_CHROME_MCP_API_KEY=
HAZIFY_SECTION_SHOPIFY_DEV_MCP_BASE_URL=
HAZIFY_SECTION_SHOPIFY_DEV_MCP_API_KEY=
HAZIFY_SECTION_COMPAT_MODE=staged

# Fallback stdio/local mode (legacy)
HAZIFY_LICENSE_KEY=
HAZIFY_LICENSE_API_BASE_URL=
HAZIFY_LICENSE_GRACE_HOURS=72
HAZIFY_LICENSE_HEARTBEAT_HOURS=6
MYSHOPIFY_DOMAIN=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
