# Transport mode
HAZIFY_MCP_TRANSPORT=http
HAZIFY_MCP_HTTP_HOST=0.0.0.0
PORT=8788
HAZIFY_MCP_HTTP_PORT=8788

# Remote MCP production mode (recommended)
HAZIFY_MCP_INTROSPECTION_URL=https://hazify-license-service-production.up.railway.app
HAZIFY_MCP_API_KEY=change-this-mcp-api-key
HAZIFY_MCP_PUBLIC_URL=https://hazify-mcp-remote-production.up.railway.app/mcp
HAZIFY_MCP_AUTH_SERVER_URL=https://hazify-license-service-production.up.railway.app
HAZIFY_MCP_ALLOWED_ORIGINS=
HAZIFY_MCP_CONTEXT_TTL_MS=120000
SHOPIFY_API_VERSION=2026-01

# Fallback stdio/local mode (legacy)
HAZIFY_LICENSE_KEY=
HAZIFY_LICENSE_API_BASE_URL=
HAZIFY_LICENSE_GRACE_HOURS=72
HAZIFY_LICENSE_HEARTBEAT_HOURS=6
MYSHOPIFY_DOMAIN=
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
