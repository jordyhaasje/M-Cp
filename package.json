{
  "name": "hazify-platform",
  "private": true,
  "version": "1.0.0",
  "description": "Hazify production monorepo for license service and remote MCP",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "generate:docs": "node scripts/generate-tool-docs.mjs",
    "check:docs": "npm run generate:docs && node scripts/check-docs.mjs",
    "check:repo": "node scripts/check-repo-hygiene.mjs",
    "check:git-sync": "node scripts/check-git-sync.mjs",
    "release:status": "node scripts/release-status.mjs",
    "release:preflight": "npm run check:docs && npm run check:repo && npm run build && npm test",
    "release:postdeploy": "npm run smoke:prod",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "build": "npm run generate:docs && npm run -ws --if-present build",
    "test": "npm run -ws --if-present test && npm run test:e2e",
    "test:e2e": "node tests/e2e/contract.test.mjs && node apps/hazify-license-service/tests/account-license-binding.test.mjs && node apps/hazify-license-service/tests/signup-auto-active-license.test.mjs",
    "start": "node scripts/start-service.mjs",
    "start:license": "HAZIFY_SERVICE_MODE=license node scripts/start-service.mjs",
    "start:mcp": "HAZIFY_SERVICE_MODE=mcp node scripts/start-service.mjs",
    "railway:link:mcp": "railway link -p Hazify-MCP-Remote -e production -s Hazify-MCP-Remote",
    "railway:link:license": "railway link -p Hazify-License-Service -e production -s Hazify-License-Service"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
